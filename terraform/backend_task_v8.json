{
    "family": "commander-backend-prod",
    "executionRoleArn": "arn:aws:iam::547456401969:role/px-ecs-exec-commander-prod",
    "taskRoleArn": "arn:aws:iam::547456401969:role/px-ecs-exec-commander-prod",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "backend",
            "image": "547456401969.dkr.ecr.us-east-1.amazonaws.com/commander-backend:prod-latest",
            "cpu": 512,
            "memory": 512,
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                { "name": "APP_ENV", "value": "prod" },
                { "name": "DATABASE_URL", "value": "postgresql://commander:changeme@localhost:5432/commander_v3" },
                { "name": "ENVIRONMENT", "value": "production" },
                { "name": "APP_NAME", "value": "commander" },
                { "name": "SECRET_KEY", "value": "your-secret-key-change-in-production" },
                { "name": "REDIS_URL", "value": "redis://localhost:6379/0" },
                { "name": "ROOT_FIX", "value": "v3" }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "efs-data",
                    "containerPath": "/app/data",
                    "readOnly": false
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/px/prod/commander",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "backend"
                }
            },
            "healthCheck": {
                "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\" || exit 1"],
                "interval": 30,
                "timeout": 10,
                "retries": 3,
                "startPeriod": 15
            }
        },
        {
            "name": "celery-worker",
            "image": "547456401969.dkr.ecr.us-east-1.amazonaws.com/commander-backend:prod-latest",
            "cpu": 256,
            "memory": 512,
            "essential": true,
            "command": ["celery", "-A", "celery_config", "worker", "--loglevel=info"],
            "environment": [
                { "name": "DATABASE_URL", "value": "postgresql://commander:changeme@localhost:5432/commander_v3" },
                { "name": "REDIS_URL", "value": "redis://localhost:6379/0" },
                { "name": "SECRET_KEY", "value": "your-secret-key-change-in-production" }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "efs-data",
                    "containerPath": "/app/data",
                    "readOnly": false
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/px/prod/commander",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "celery-worker"
                }
            }
        },
        {
            "name": "celery-beat",
            "image": "547456401969.dkr.ecr.us-east-1.amazonaws.com/commander-backend:prod-latest",
            "cpu": 128,
            "memory": 256,
            "essential": true,
            "command": ["celery", "-A", "celery_config", "beat", "--loglevel=info"],
            "environment": [
                { "name": "DATABASE_URL", "value": "postgresql://commander:changeme@localhost:5432/commander_v3" },
                { "name": "REDIS_URL", "value": "redis://localhost:6379/0" },
                { "name": "SECRET_KEY", "value": "your-secret-key-change-in-production" }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "efs-data",
                    "containerPath": "/app/data",
                    "readOnly": false
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/px/prod/commander",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "celery-beat"
                }
            }
        },
        {
            "name": "postgres",
            "image": "postgres:15-alpine",
            "cpu": 0,
            "essential": true,
            "environment": [
                { "name": "POSTGRES_USER", "value": "commander" },
                { "name": "POSTGRES_PASSWORD", "value": "changeme" },
                { "name": "POSTGRES_DB", "value": "commander_v3" }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/px/prod/commander",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "postgres"
                }
            },
            "healthCheck": {
                "command": ["CMD-SHELL", "pg_isready -U commander"],
                "interval": 10,
                "timeout": 5,
                "retries": 5
            }
        },
        {
            "name": "redis",
            "image": "redis:7-alpine",
            "cpu": 0,
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/px/prod/commander",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "redis"
                }
            },
            "healthCheck": {
                "command": ["CMD", "redis-cli", "ping"],
                "interval": 10,
                "timeout": 3,
                "retries": 5
            }
        }
    ],
    "volumes": [
        {
            "name": "efs-data",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-0c456eb317a5be9cb",
                "rootDirectory": "/",
                "transitEncryption": "ENABLED"
            }
        }
    ],
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "1024",
    "memory": "2048"
}
