# ─────────────────────────────────────────────────────────────────────────────
# secrets.yaml.template — Project X Baseline Secrets
# Copy this to 'secrets.yaml' and fill in the values for local development.
# IMPORTANT: 'secrets.yaml' is in .gitignore and MUST NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

snowflake:
  account: "your-account-id"      # e.g. pxltd-dev
  user: "YOUR_SVC_USER"           # e.g. SAUCE_SVC
  role: "YOUR_APP_ROLE"           # e.g. SAUCE_ROLE
  database: "PX_B_YOUR_APP_DEV" 
  warehouse: "PX_APP_WH"
  private_key_path: "snowflake_key.p8" # Path to your RSA private key file

aws:
  region: "ca-central-1"
  profile: "px-dev"

# Add your app-specific secrets below
app_secrets:
  # OPENAI_API_KEY: "sk-..."
  # SLACK_TOKEN: "xoxb-..."

runtime_vars:
  ENVIRONMENT: "dev"
  LOG_LEVEL: "INFO"
